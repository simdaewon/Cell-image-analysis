import matplotlib.pyplot as plt
import numpy as np
import os
import torchvision.transforms as transforms
from torchvision.transforms import InterpolationMode
from PIL import Image

train_data_dir = '/home/won/ResNet/train' 
class_names = ['D1', 'D2', 'D3']
num_examples = 5
patch_size = 224

#전처리 파이프라인: 무작위 회전 후 무작위 자르기
transform_pipeline = transforms.Compose([
    transforms.RandomCrop(400),  # 1. 넉넉하게 400x400 크기로 뭉텅 잘라오기
    transforms.RandomRotation(30, interpolation=InterpolationMode.BILINEAR), # 2. 회전 (모서리에 검은색 생김)
    transforms.CenterCrop(patch_size) # 3. 정중앙 224x224만
])

fig, axs = plt.subplots(len(class_names), num_examples, figsize=(num_examples * 3, len(class_names) * 3))

for i, class_name in enumerate(class_names):
    class_path = os.path.join(train_data_dir, class_name)
    images = [f for f in os.listdir(class_path) if f.endswith(('.jpg', '.png'))]
    
    # 클래스별로 무작위로 사진 한 장 선택
    random_img_name = np.random.choice(images)
    img_path = os.path.join(class_path, random_img_name)
    original_img = Image.open(img_path).convert('RGB')
    
    for j in range(num_examples):
        #수동 crop 대신 파이토치 transform 파이프라인 적용
        patch = transform_pipeline(original_img)
        
        # 시각화 (좌표축 제거)
        axs[i, j].imshow(patch)
        axs[i, j].axis('off')
        if j == 0:
            axs[i, j].set_title(f"{class_name} (Example patches)", fontsize=16, weight='bold')

# 3. 저장
save_path = '/home/won/ResNet/Figure/Rotation_30_v2.jpg'

os.makedirs(os.path.dirname(save_path), exist_ok=True) 

plt.tight_layout()
plt.savefig(save_path, dpi=300)
print(f"💾 갤러리 이미지 저장 완료: {save_path}")
plt.show()



import matplotlib.pyplot as plt
import numpy as np
import os
import torchvision.transforms as transforms
from PIL import Image

train_data_dir = '/home/won/ResNet/train' 
class_names = ['D1', 'D2', 'D3']
num_examples = 5  # 1 Original + 4 Augmented

# 밝기 및 대비 조절 변환기 설정
color_only_transform = transforms.ColorJitter(brightness=0.1, contrast=0.1)

# 3행(D1,D2,D3) 5열 도화지 준비
fig, axs = plt.subplots(len(class_names), num_examples, figsize=(num_examples * 3, len(class_names) * 3))

for i, class_name in enumerate(class_names):
    class_path = os.path.join(train_data_dir, class_name)
    images = [f for f in os.listdir(class_path) if f.endswith(('.jpg', '.png'))]
    
    # 클래스별로 무작위로 사진 한 장 선택
    random_img_name = np.random.choice(images)
    img_path = os.path.join(class_path, random_img_name)
    original_img = Image.open(img_path).convert('RGB')
    
    # 첫 번째 칸(j=0): 원본 이미지 고정
    axs[i, 0].imshow(original_img)
    axs[i, 0].set_title(f"{class_name} Original", weight='bold', fontsize=14)
    axs[i, 0].axis('off')
    
    # 나머지 4칸(j=1~4): ColorJitter(밝기/대비 조절) 무작위 적용
    for j in range(1, num_examples):
        aug_img = color_only_transform(original_img)
        axs[i, j].imshow(aug_img)
        axs[i, j].set_title(f"Random Color {j}")
        axs[i, j].axis('off')

# 저장 경로 설정 및 저장
save_path = '/home/won/ResNet/Figure/Bright_0.1.jpg'
os.makedirs(os.path.dirname(save_path), exist_ok=True) 

plt.tight_layout()
plt.savefig(save_path, dpi=300)
print(f"💾 갤러리 이미지 저장 완료: {save_path}")
plt.show()
